APP_NAME="ChatBot System"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_KEY=base64:CHANGE_THIS_TO_A_RANDOM_32_CHAR_STRING

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=chatbot
DB_USERNAME=root
DB_PASSWORD=

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@chatbot.local
MAIL_FROM_NAME="ChatBot System"

SESSION_LIFETIME=120
SESSION_SECURE=false

TIMEZONE=America/Sao_Paulo
LOCALE=pt_BR

# License (leave empty to run in development/unlimited mode)
LICENSE_API_URL=https://yourserver.com/public_api
LICENSE_KEY=your-license-key-here

# Git binary path (optional — set if auto-detection fails, e.g. cPanel)
# Run "which git" via SSH to get the correct path
# GIT_PATH=/usr/local/cpanel/3rdparty/bin/git

# Owner license DB (only needed on the owner's server)
LICENSE_DB_HOST=localhost
LICENSE_DB_DATABASE=chatbot_licenses
LICENSE_DB_USERNAME=root
LICENSE_DB_PASSWORD=

# Owner panel credentials (run public_owner/setup.php to generate hash)
OWNER_USERNAME=admin
OWNER_PASSWORD_HASH=
